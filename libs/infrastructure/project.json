{
  "name": "infrastructure",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/infrastructure/src",
  "projectType": "library",
  "tags": ["scope:infrastructure"],
  "targets": {
    "prisma-generate": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/infrastructure/src/generated/prisma"
      ],
      "options": {
        "command": "npx prisma generate --config=libs/infrastructure/prisma/prisma.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "dependsOn": ["prisma-generate"],
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/infrastructure",
        "main": "libs/infrastructure/src/index.ts",
        "tsConfig": "libs/infrastructure/tsconfig.lib.json",
        "assets": ["libs/infrastructure/*.md"]
      }
    }
  }
}
