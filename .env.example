# Database
DATABASE_URL=postgresql://datashelf:datashelf@localhost:5432/datashelf?schema=public
POSTGRES_USER=datashelf
POSTGRES_PASSWORD=datashelf
POSTGRES_DB=datashelf

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
JWT_EXPIRES_IN_SECONDS=86400

# API
API_PORT=3000

# Frontend (must match the URL users open in the browser, e.g. docker maps web:80 -> localhost:4200)
FRONTEND_URL=http://localhost:4200

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400
